# --------------------------------------------------------------------
# CODEOWNERS for node-ui-example E2E stacks
#
# Purpose:
# - Automatically request reviews from:
#     * QA Automation Lead
#     * DevOps Engineer
#     * Platform Lead
#     * SRE (where infra/audit is affected)
#
# Scope:
# - Playwright / Cypress E2E
# - Selenium Grid CI workflows
# - Audit evidence & governance files
#
# NOTE:
# - Replace team names with real GitHub teams if needed.
# --------------------------------------------------------------------

# --------------------------------------------------------------------
# E2E Workflow Wiring
# --------------------------------------------------------------------
.github/workflows/e2e-playwright-demo.yml \
  @BrikByte-Studios/qa-automation \
  @BrikByte-Studios/devops \
  @BrikByte-Studios/platform-leads

.github/workflows/e2e-selenium.yml \
  @BrikByte-Studios/qa-automation \
  @BrikByte-Studios/devops \
  @BrikByte-Studios/platform-leads

# --------------------------------------------------------------------
# Playwright / Cypress Configuration
# --------------------------------------------------------------------
**/playwright.config.ts \
  @BrikByte-Studios/qa-automation \
  @BrikByte-Studios/devops

**/cypress.config.cjs \
  @BrikByte-Studios/qa-automation \
  @BrikByte-Studios/devops

# --------------------------------------------------------------------
# Integration Tests (All Languages)
# --------------------------------------------------------------------
**/tests/integration/** \
  @BrikByte-Studios/qa-automation \
  @BrikByte-Studios/platform-leads

# --------------------------------------------------------------------
# E2E Tests (Playwright / Cypress / Selenium)
# --------------------------------------------------------------------
**/tests/e2e/** \
  @BrikByte-Studios/qa-automation \
  @BrikByte-Studios/platform-leads \
  @BrikByte-Studios/devops

# --------------------------------------------------------------------
# CI / Pipeline Governance
# --------------------------------------------------------------------
.github/workflows/** \
  @BrikByte-Studios/platform-leads

.github/policy.yml \
  @BrikByte-Studios/platform-leads

# --------------------------------------------------------------------
# Audit & Compliance Evidence
# --------------------------------------------------------------------
.audit/** \
  @BrikByte-Studios/platform-leads \
  @BrikByte-Studios/devops \
  @BrikByte-Studios/sre

# --------------------------------------------------------------------
# Catch-all (REQUIRED – must be last)
# --------------------------------------------------------------------
* \
  @BrikByte-Studios/platform-leads \
  @BrikByte-Studios/sre
