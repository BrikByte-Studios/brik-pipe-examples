# .env.integ.example
# -------------------
# Template for integration environment variables.
# COPY this file to `.env.integ.local` for local dev only.
# DO NOT COMMIT `.env.integ.local` or any real secrets.

# Database (integration)
INTEG_DB_USER=
INTEG_DB_PASS=
INTEG_DB_NAME=app_test
INTEG_DB_HOST=localhost
INTEG_DB_PORT=5432

# Test-only JWT secret (non-production)
JWT_SECRET_TEST=
