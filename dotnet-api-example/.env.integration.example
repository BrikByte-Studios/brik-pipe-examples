# Integration env contract (SAFE TEMPLATE)
# Copy to .env.integration for local dev. NEVER commit .env.integration.

TEST_DB_VENDOR=postgres
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=app_test
TEST_DB_USER=app
TEST_DB_PASSWORD=change-me-locally
# Prefer URL if your stack uses it
TEST_DB_URL=postgresql://app:change-me-locally@localhost:5432/app_test

TEST_REDIS_URL=redis://localhost:6379

TEST_MOCK_BASE_URL=http://localhost:8080

INTEGRATION_TIMEOUT_SECONDS=180
INTEGRATION_SEED_MODE=auto